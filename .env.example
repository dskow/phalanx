# Anthropic API key for the agents. Required.
ANTHROPIC_API_KEY=

# Model identifier. Defaults to claude-sonnet-4-6 in code.
# Override only if you have a specific reason.
PHALANX_MODEL=claude-sonnet-4-6

# Audit log verbosity. One of: minimal, standard, verbose.
PHALANX_AUDIT=standard

# Hard cap on agent iterations per run. Prevents runaway loops
# if the reviewer never reaches PASS.
PHALANX_MAX_ITERATIONS=4
